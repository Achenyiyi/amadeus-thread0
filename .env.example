# DeepSeek
DEEPSEEK_API_KEY=""

# LangSmith（tracing + 项目归档）
LANGSMITH_API_KEY=""
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=amadeus-thread0
# 可选：若你是自建 LangSmith 才需要
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Qwen3-TTS（DashScope Realtime + 声音复刻）
AMADEUS_TTS_ENABLED=1
AMADEUS_TTS_BACKEND="dashscope_realtime"

# 声音复刻（enrollment）：参考音频（官方示例做法）
AMADEUS_TTS_REF_AUDIO="data/copy_wav/your_ref.wav"

# DashScope 配置（北京地域）
DASHSCOPE_API_KEY=""
AMADEUS_TTS_DASHSCOPE_WS_URL="wss://dashscope.aliyuncs.com/api-ws/v1/realtime"
# 合成模型（Realtime）
AMADEUS_TTS_DASHSCOPE_MODEL="qwen3-tts-vc-realtime-2026-01-15"
# 声音复刻 enrollment 的 target_model（通常与合成模型保持一致）
AMADEUS_TTS_DASHSCOPE_TARGET_MODEL="qwen3-tts-vc-realtime-2026-01-15"
AMADEUS_TTS_DASHSCOPE_PREFERRED_NAME="amadeus"
AMADEUS_TTS_DASHSCOPE_AUDIO_MIME="audio/wav"
AMADEUS_TTS_DASHSCOPE_ENROLL_URL="https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization"

# 可选：参考文本（目前 enrollment 不使用，但保留接口，便于未来做更精细的说话人适配）
AMADEUS_TTS_REF_TEXT=""

# Amadeus 运行目录/线程
AMADEUS_DATA_DIR="data"
AMADEUS_CHECKPOINT_DB=""
AMADEUS_MEMORY_DB=""
AMADEUS_DIARY_PATH=""
AMADEUS_USER_ID="me"
AMADEUS_THREAD_ID="thread0"

# DeepSeek 模型参数
AMADEUS_DEEPSEEK_MODEL="deepseek-chat"
AMADEUS_TEMPERATURE=0.5

# Embeddings（moments/reflections 检索用）
AMADEUS_EMBEDDING_MODEL="Qwen/Qwen3-Embedding-0.6B"
AMADEUS_EMBEDDING_DEVICE="cpu"
AMADEUS_EMBEDDING_NORMALIZE=1
AMADEUS_EMBEDDING_TRUST_REMOTE_CODE=1

# sqlite-vec（可选）：auto=尽力启用；on=强制启用（失败直接报错）；off=禁用
AMADEUS_SQLITE_VEC=auto

# Tool registry 配置（可选）
AMADEUS_TOOL_REGISTRY_JSON=""
# LangChain Docs MCP URL（search_langchain_docs 工具使用）
AMADEUS_LANGCHAIN_DOCS_MCP_URL="https://docs.langchain.com/mcp"

# Tool runtime guard（可选；默认值见 amadeus_thread0/config.py）
AMADEUS_TOOL_CALLS_MAX=6
AMADEUS_TOOL_TIMEOUT_S=25

# Toolset upgrade TTL（可选）：升级后临时解锁的有效期（秒）
AMADEUS_TOOLSET_TTL_S=600

# Legacy tables（profile/relationship）：默认关闭（已迁移到 store_kv 后不应再生成旧表）
# 如需兼容/从旧库迁移，再手动开启。
AMADEUS_LEGACY_TABLES=0

# MCP（外部能力口子）：默认禁用；开启前请配置 allowlist
AMADEUS_MCP_ENABLED=0
# 允许的 MCP server id/name（逗号分隔）。注意：仅 allowlist 中的 server 才会被考虑加载。
AMADEUS_MCP_SERVER_ALLOWLIST=
# 允许的 MCP tool 名称（逗号分隔）。用于 server 通过后的二次筛选（预埋）。
AMADEUS_MCP_TOOL_ALLOWLIST=
# MCP 调用底线（预埋；真正接入 adapter 时使用）
AMADEUS_MCP_CALLS_MAX=4
AMADEUS_MCP_TIMEOUT_S=25
